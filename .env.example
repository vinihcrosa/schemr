# Database connection string for Prisma
DATABASE_URL=

# NextAuth v5 secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# NextAuth v5 canonical URL
AUTH_URL=

# Postgres credentials (used by docker-compose)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Integration test database (points to schemr_test DB)
TEST_DATABASE_URL=
